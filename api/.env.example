APP_NAME=ForecastHub API
ENVIRONMENT=development
DATABASE_URL=sqlite:///./forecast_hub.db
FRONTEND_ORIGIN=http://localhost:5173

DEFAULT_LOCATION_NAME=Chicago
DEFAULT_LOCATION_LATITUDE=41.8781
DEFAULT_LOCATION_LONGITUDE=-87.6298
DEFAULT_LOCATION_TIMEZONE=America/Chicago

SCHEDULER_JOB_TOKEN=replace-me
OPENAI_API_KEY=sample-key
OPENAI_MODEL=gpt-4o-mini

MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=forecast_hub_temperature
MLFLOW_MODEL_NAME=forecast_hub_next_hour_temperature
MODEL_MIN_TRAINING_ROWS=200
MODEL_PROMOTE_RMSE_MARGIN=0.995

NOTIFICATION_SCHEDULER_ENABLED=true
NOTIFICATION_SCHEDULER_INTERVAL_SECONDS=60
NOTIFICATION_JOB_BATCH_SIZE=20
NOTIFICATION_MAX_RETRIES=3
NOTIFICATION_RETRY_BACKOFF_SECONDS=60,300,900

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_USE_TLS=true
